---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { languages, useTranslations } from '../../i18n';

export function getStaticPaths() {
	return Object.keys(languages).map(lang => ({
		params: { lang },
	}));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{lang === 'zh' ? '🧑‍🚀 你好，宇航员！' : '🧑‍🚀 Hello, Astronaut!'}</h1>
			<p>
				{lang === 'zh'
					? '欢迎来到官方的 Astro 博客起始模板。这个模板为想要使用 Astro 构建个人网站、博客或作品集的人提供了一个轻量级、最小化风格的起点。'
					: 'Welcome to the official Astro blog starter template. This template serves as a lightweight, minimally-styled starting point for anyone looking to build a personal website, blog, or portfolio with Astro.'}
			</p>
			<p>
				{lang === 'zh'
					? '此模板已在您的 astro.config.mjs 文件中配置了一些集成。您可以使用 Astro Integrations 自定义您的设置，添加 Tailwind、React 或 Vue 等工具。'
					: 'This template comes with a few integrations already configured in your astro.config.mjs file. You can customize your setup with Astro Integrations to add tools like Tailwind, React, or Vue to your project.'}
			</p>
			<p>{lang === 'zh' ? '以下是使用此模板的一些入门建议：' : 'Here are a few ideas on how to get started with the template:'}</p>
			<ul>
				<li>{lang === 'zh' ? '在 src/pages/[lang]/index.astro 中编辑此页面' : 'Edit this page in <code>src/pages/[lang]/index.astro</code>'}</li>
				<li>{lang === 'zh' ? '在 src/components/Header.astro 中编辑网站导航项' : 'Edit the site header items in <code>src/components/Header.astro</code>'}</li>
				<li>{lang === 'zh' ? '在 src/components/Footer.astro 中添加您的名字' : 'Add your name to the footer in <code>src/components/Footer.astro</code>'}</li>
				<li>{lang === 'zh' ? '查看 src/content/blog/ 中的博客文章' : 'Check out the included blog posts in <code>src/content/blog/</code>'}</li>
				<li>{lang === 'zh' ? '在 src/layouts/BlogPost.astro 中自定义博客文章页面布局' : 'Customize the blog post page layout in <code>src/layouts/BlogPost.astro</code>'}</li>
			</ul>
			<p>
				{lang === 'zh' ? '玩得开心！如果遇到困难，记得查看文档或加入 Discord 向我们提问。' : 'Have fun! If you get stuck, remember to read the docs or join us on Discord to ask questions.'}
			</p>
			<p>
				{lang === 'zh' ? '想要更具个性的博客模板？去看看' : 'Looking for a blog template with a bit more personality? Check out'}
				<a href="https://github.com/Charca/astro-blog-template">astro-blog-template</a>
				{lang === 'zh' ? '，作者是' : ' by '}<a href="https://twitter.com/Charca">Maxi Ferreira</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
