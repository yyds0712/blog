---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { languages, useTranslations } from '../../i18n';

export function getStaticPaths() {
	return Object.keys(languages).map(lang => ({
		params: { lang },
	}));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{lang === 'zh' ? '👋 你好，我是 yyds0712' : '👋 Hi, I\'m yyds0712'}</h1>
			<p>
				{lang === 'zh'
					? '一名大学生，在这里记录我眼中的 AI 时代。'
					: 'A college student documenting the AI era through my eyes.'}
			</p>
			<p>
				{lang === 'zh'
					? '生活记录 · 学习笔记 · 工具分享'
					: 'Life notes · Study logs · Tool reviews'}
			</p>
			<hr />
			<section>
				<h2>{lang === 'zh' ? '最新文章' : 'Latest Posts'}</h2>
				<p><a href={`/${lang}/blog/`}>{lang === 'zh' ? '查看全部文章 →' : 'View all posts →'}</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>
