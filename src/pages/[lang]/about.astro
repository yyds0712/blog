---
import Layout from '../../layouts/BlogPost.astro';
import { languages, useTranslations } from '../../i18n';

export function getStaticPaths() {
	return Object.keys(languages).map(lang => ({
		params: { lang },
	}));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const aboutTitle = lang === 'zh' ? '关于我' : 'About Me';
const aboutDescription = lang === 'zh' ? '一名大学生在 AI 时代的生活记录' : 'A college student in the AI era';
---

<Layout
	title={aboutTitle}
	description={aboutDescription}
	pubDate={new Date('June 19 2026')}
	heroImage="/blog-placeholder-about.jpg"
>
	{lang === 'zh' ? (
		<>
			<p>你好，我是 yyds0712，一名大学生。</p>
			<p>这个网站记录了我的生活、学习和思考。在 AI 时代，我想做一个真实的人，分享真实的内容。</p>
			<p>如果你也有兴趣，欢迎通过 GitHub 与我联系。</p>
		</>
	) : (
		<>
			<p>Hi, I'm yyds0712, a college student.</p>
			<p>This site is where I document my life, studies, and thoughts. In the age of AI, I want to be a real person sharing real content.</p>
			<p>Feel free to reach out on GitHub if you're interested.</p>
		</>
	)}
</Layout>
