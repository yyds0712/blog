---
// Redirect to language-specific pages
import { type CollectionEntry, getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	// Redirect all old blog paths to the new language routes
	return posts.map(post => ({
		params: { slug: post.id },
		props: { slug: post.id },
	}));
}

const { slug } = Astro.params;
---

<!doctype html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width,initial-scale=1" />
	<title>Redirecting...</title>
	<script is:inline>
		(function() {
			const stored = localStorage.getItem('language');
			let targetLang = stored;

			if (!targetLang) {
				const browserLang = navigator.language || navigator.userLanguage;
				targetLang = browserLang.toLowerCase().startsWith('zh') ? 'zh' : 'en';
			}

			const slug = window.location.pathname.split('/').filter(Boolean).pop();
			const langPath = targetLang === 'en' ? '/en/blog/' : '/' + targetLang + '/blog/';
			window.location.href = langPath + slug + '/';
		})();
	</script>
</head>
<body>
	<p>Redirecting...</p>
</body>
</html>
